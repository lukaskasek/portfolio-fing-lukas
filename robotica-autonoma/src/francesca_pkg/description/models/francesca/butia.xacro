<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:include filename="inertial_macros.xacro" />
  <xacro:include filename="dimensions_macros.xacro" />
  <xacro:include filename="materials_macros.xacro" />

  <!-- CHASSIS -->
  <!-- The origin is at the center of the top of the main plaque -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
      </geometry>
      <origin xyz="0 0 -${chassis_height/2}" rpy="0 0 0" />
      <material name="blue" />
    </visual>
    <collision>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}" />
      </geometry>
      <origin xyz="0 0 -${chassis_height/2}" rpy="0 0 0" />
    </collision>
    <xacro:inertial_box mass="${chassis_weight}" x="${chassis_length}" y="${chassis_width}"
      z="${chassis_height}">
      <origin xyz="0 0 -${chassis_height/2}" rpy="0 0 0" />
    </xacro:inertial_box>
  </link>

  <!-- WHEELS -->
  <link name="left_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <material name="red" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
    </collision>
    <xacro:inertial_cylinder mass="0.05" length="${wheel_width}" radius="${wheel_radius}">
      <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="left_wheel_link" />
    <origin xyz="${wheel_offset_length} ${wheel_offset_width} ${wheel_offset_height}"
      rpy="0 0 0" />
    <axis xyz="0 1 0 " />
  </joint>

  <link name="right_wheel_link">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <material name="red" />
    </visual>
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}" />
      </geometry>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
    </collision>
    <xacro:inertial_cylinder mass="0.05" length="${wheel_width}" radius="${wheel_radius}">
      <origin xyz="0 0 0" rpy="1.57 0 0" />
    </xacro:inertial_cylinder>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link" />
    <child link="right_wheel_link" />
    <origin xyz="${wheel_offset_length} ${-wheel_offset_width} ${wheel_offset_height}"
      rpy="0 0 0" />
    <axis xyz="0 1 0 " />
  </joint>

  <!-- CASTER -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}" />
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <material name="red" />
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}" />
        <origin xyz="0 0 0" rpy="0 0 0" />
      </geometry>
    </collision>
    <xacro:inertial_sphere mass="0.01" radius="${caster_radius}">
      <origin xyz="0 0 0" rpy="0 0 0" />
    </xacro:inertial_sphere>
  </link>
  <joint name="base_caster_joint" type="fixed">
    <parent link="base_link" />
    <child link="caster_link" />
    <origin xyz="${caster_offset_length} 0 ${wheel_offset_height-wheel_radius + caster_radius}"
      rpy="0 0 0" />
  </joint>
  <gazebo reference="caster_link">
    <mu>0.01</mu>
    <mu2>0.01</mu2>
  </gazebo>

  <!-- BASE FOOTPRINT -->
  <link name="base_footprint" />
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint" />
    <child link="base_link" />
    <origin xyz="0 0 ${wheel_radius-wheel_offset_height}" rpy="0 0 0" />
  </joint>


</robot>
